# TokenMeter Configuration
# 复制此文件为 config.yaml 并根据需要修改

server:
  host: 0.0.0.0
  port: 8080
  
database:
  # SQLite 数据库路径
  path: ./data/tokenmeter.db
  
# MaaS 提供商配置
providers:
  openai:
    enabled: true
    base_url: https://api.openai.com
    # API Key 通过环境变量 OPENAI_API_KEY 设置
    
  azure:
    enabled: false
    # Azure OpenAI 配置
    # base_url: https://your-resource.openai.azure.com
    # api_key: 通过环境变量 AZURE_OPENAI_KEY 设置
    
  claude:
    enabled: false
    base_url: https://api.anthropic.com
    # API Key 通过环境变量 ANTHROPIC_API_KEY 设置

# 预算配置
budget:
  enabled: true
  default_currency: USD
  
# 告警配置
alerts:
  webhook_url: ""  # 飞书/钉钉/Slack Webhook URL
  email: []        # 告警邮箱列表
  
# 日志配置
logging:
  level: INFO  # DEBUG, INFO, WARNING, ERROR
  file: ./logs/tokenmeter.log